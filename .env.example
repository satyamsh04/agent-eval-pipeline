# ─────────────────────────────────────────────────────────────
# Agent Reliability & Evaluation Pipeline — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- API server ---
PORT=3000
NODE_ENV=development

# --- API auth (leave blank to disable auth locally; set to enforce x-api-key) ---
API_KEY=your-secret-here

# --- Evaluation thresholds (override defaults if needed) ---
HALLUCINATION_THRESHOLD=0.70
REGRESSION_TOLERANCE=0.05

# --- Optional LLM provider keys (Phase 2 — NOT required for offline core eval) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- AWS (Phase 3 — persistence / deploy) ---
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_TABLE=agent-eval-history
S3_BUCKET=agent-eval-fixtures

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
