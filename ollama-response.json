    "response":  "```typescript\nimport { cosineSimilarity, splitSentences } from \u0027../utils/text\u0027;\n\n/**\n * Evaluates the faithfulness of the given output against the provided context.\n * @param output - The generated text to be evaluated.\n * @param context - An array of context strings.\n * @returns A score between 0 and 1 indicating the faithfulness of the output, with higher values being more faithful.\n */\nexport class RagasEvaluator {\n    /**\n     * Clamps a value between 0 and 1.\n     * @private\n     * @param value - The value to clamp.\n     * @returns The clamped value.\n     */\n    private clamp01(value: number): number {\n        return Math.min(Math.max(value, 0), 1);\n    }\n\n    /**\n     * Evaluates the faithfulness of the given output against the provided context.\n     * @param output - The generated text to be evaluated.\n     * @param context - An array of context strings.\n     * @returns A score between 0 and 1 indicating the faithfulness of the output, with higher values being more faithful.\n     */\n    public evaluateFaithfulness(output: string, context: string[]): number {\n        if (output === \u0027\u0027 || context.length === 0) {\n            return 0;\n        }\n\n        const sentences = splitSentences(output);\n        let totalSimilarity = 0;\n\n        for (const sentence of sentences) {\n            let maxSimilarity = 0;\n            for (const chunk of context) {\n                const similarity = cosineSimilarity(sentence, chunk);\n                if (similarity \u003e maxSimilarity) {\n                    maxSimilarity = similarity;\n                }\n            }\n            totalSimilarity += maxSimilarity;\n        }\n\n        return this.clamp01(totalSimilarity / sentences.length);\n    }\n}\n```",
